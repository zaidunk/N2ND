# n2nd (Attention Boost) — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.

# ─── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# ─── Upstash Redis ─────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# ─── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Cloudflare R2 (optional for raw archive) ─────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=n2nd-raw

# ─── BI Rate fallback (if live fetch fails) ────────────────────────────────────
BI_RATE_DEFAULT=6.0

# ─── Admin API (for /refresh endpoints — keep secret) ─────────────────────────
ADMIN_API_KEY=generate-a-strong-random-key-here

# ─── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://n2nd.ai,http://localhost:3000

# ─── OJK (optional — leave blank to use public fallback) ──────────────────────
OJK_API_KEY=

# ─── Scheduler intervals (seconds) — override defaults ─────────────────────────
RSS_INTERVAL=900
MARKET_INTERVAL=600
CRYPTO_INTERVAL=300
FOREX_INTERVAL=3600
BMKG_INTERVAL=1800
GDELT_INTERVAL=3600
OJK_INTERVAL=86400
IDX_INTERVAL=300
BPS_INTERVAL=604800
HEALTH_INTERVAL=120
